DATABASE_URL=postgresql://postgres:postgres@localhost:5432/codefest

# LLM-провайдер для автоматического распределения расписания: yandex (default) или gigachat
LLM_PROVIDER=yandex

# YandexGPT
# Получить: https://yandex.cloud/ru/docs/foundation-models/quickstart/yandexgpt
YANDEX_API_KEY=
YANDEX_FOLDER_ID=
# Модель: yandexgpt/latest (pro) или yandexgpt-lite/latest (быстрее, дешевле)
YANDEX_MODEL=yandexgpt/latest

# GigaChat (используется при LLM_PROVIDER=gigachat)
# Получить credentials: https://developers.sber.ru/portal/products/gigachat-api
# GIGACHAT_CREDENTIALS = base64(client_id:secret)
GIGACHAT_CREDENTIALS=
# GIGACHAT_API_PERS (физ. лицо) или GIGACHAT_API_CORP (юр. лицо)
GIGACHAT_SCOPE=GIGACHAT_API_PERS
# Модели: GigaChat, GigaChat-Pro, GigaChat-Max
GIGACHAT_MODEL=GigaChat-Pro
# Путь к CA-bundle для SSL-верификации GigaChat (Сбер использует сертификат Минцифры).
# Запустите `make download-certs` для скачивания. Установите false чтобы отключить верификацию.
GIGACHAT_CA_BUNDLE=certs/sber_ca_bundle.pem

# Ротация логов: удалять записи старше N дней (0 = не удалять)
LOG_RETENTION_DAYS=30
